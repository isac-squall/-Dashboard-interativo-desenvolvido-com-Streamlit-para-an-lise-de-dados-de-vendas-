[build-system]
requires = ["setuptools>=65.0", "wheel"]
build-backend = "setuptools.build_meta"

[project]
name = "supermarket-dashboard"
version = "1.0.0"
description = "Dashboard interativo de análise de vendas de supermercado com Streamlit"
readme = "README.md"
requires-python = ">=3.10"
license = {text = "MIT"}
authors = [
    {name = "Data Engineering Team", email = "dev@example.com"}
]
keywords = ["streamlit", "dashboard", "sales", "data-analysis"]
classifiers = [
    "Development Status :: 4 - Beta",
    "Intended Audience :: Business/Finance",
    "License :: OSI Approved :: MIT License",
    "Programming Language :: Python :: 3",
    "Programming Language :: Python :: 3.10",
    "Programming Language :: Python :: 3.11",
    "Programming Language :: Python :: 3.12",
]

dependencies = [
    "streamlit>=1.37.0",
    "pandas>=2.2.0",
    "plotly>=5.18.0",
    "openpyxl>=3.1.0",
    "xlrd>=2.0.1",
]

[project.optional-dependencies]
dev = [
    "black>=23.0.0",
    "flake8>=6.0.0",
    "mypy>=1.0.0",
    "pytest>=7.0.0",
    "pytest-cov>=4.0.0",
]

[project.urls]
Homepage = "https://github.com/seu-usuario/dash.pyton"
Issues = "https://github.com/seu-usuario/dash.pyton/issues"
Repository = "https://github.com/seu-usuario/dash.pyton"

[tool.black]
line-length = 100
target-version = ["py310", "py311", "py312"]
include = '\.pyi?$'

[tool.isort]
profile = "black"
line_length = 100

[tool.mypy]
python_version = "3.10"
warn_return_any = true
warn_unused_configs = true
disallow_untyped_defs = false
