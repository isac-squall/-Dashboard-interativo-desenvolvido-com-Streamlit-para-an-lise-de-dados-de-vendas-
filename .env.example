# Arquivo de exemplo de variáveis de ambiente
# Copie este arquivo para .env e preencha os valores

# Configurações da Aplicação
APP_NAME=Dashboard de Vendas
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Configurações do Banco de Dados (se necessário no futuro)
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=dashboard_db
# DB_USER=admin
# DB_PASSWORD=seu_password

# Configurações Streamlit
STREAMLIT_SERVER_PORT=8501
STREAMLIT_LOGGER_LEVEL=info
STREAMLIT_CLIENT_SHOW_ERROR_DETAILS=true

# Configurações de Segurança
SECRET_KEY=sua_chave_secreta_aqui
API_KEY=sua_api_key_aqui

# Configurações de Email (para notificações futuras)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=seu_email@gmail.com
# SENDER_PASSWORD=sua_senha

# Ambiente
ENVIRONMENT=development  # development, staging, production
DEBUG=true
